{
  "name": "XU-News-AI-RAG 语义检索工作流",
  "nodes": [
    {
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300],
      "parameters": {
        "path": "search",
        "responseMode": "responseNode"
      }
    },
    {
      "name": "Embedding查询",
      "type": "n8n-nodes-base.httpRequest",
      "position": [450, 300],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:11434/api/embeddings",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {"name": "model", "value": "all-minilm:latest"},
            {"name": "prompt", "value": "={{$json.query}}"}
          ]
        }
      }
    },
    {
      "name": "FAISS检索",
      "type": "n8n-nodes-base.httpRequest",
      "position": [650, 300],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:5000/api/search/faiss",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {"name": "embedding", "value": "={{$json.embedding}}"}
          ]
        }
      }
    },
    {
      "name": "IF判断相似度",
      "type": "n8n-nodes-base.if",
      "position": [850, 300],
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{$json.similarity}}",
              "operation": "larger",
              "value2": 0.6
            }
          ]
        }
      }
    },
    {
      "name": "返回本地结果",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [1050, 200],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{$json}}"
      }
    },
    {
      "name": "百度搜索兜底",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1050, 400],
      "parameters": {
        "method": "GET",
        "url": "https://www.baidu.com/s?wd={{$node['Webhook'].json.query}}",
        "options": {
          "redirect": {"follow": true}
        }
      }
    },
    {
      "name": "Ollama推理",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1250, 400],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:11434/api/generate",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {"name": "model", "value": "qwen2.5:3b"},
            {"name": "prompt", "value": "请根据以下搜索结果回答用户问题：\n问题：{{$node['Webhook'].json.query}}\n搜索结果：{{$json.body}}"},
            {"name": "stream", "value": false}
          ]
        }
      }
    },
    {
      "name": "返回联网结果",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [1450, 400],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{$json}}"
      }
    }
  ],
  "connections": {
    "Webhook": {"main": [[{"node": "Embedding查询", "type": "main", "index": 0}]]},
    "Embedding查询": {"main": [[{"node": "FAISS检索", "type": "main", "index": 0}]]},
    "FAISS检索": {"main": [[{"node": "IF判断相似度", "type": "main", "index": 0}]]},
    "IF判断相似度": {
      "main": [
        [{"node": "返回本地结果", "type": "main", "index": 0}],
        [{"node": "百度搜索兜底", "type": "main", "index": 0}]
      ]
    },
    "百度搜索兜底": {"main": [[{"node": "Ollama推理", "type": "main", "index": 0}]]},
    "Ollama推理": {"main": [[{"node": "返回联网结果", "type": "main", "index": 0}]]}
  }
}
